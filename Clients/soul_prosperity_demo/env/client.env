# ============================================================
# Clients/soul_prosperity_demo/env/client.env
# AI COO Master - Soul Prosperity Demo Client Environment
# Fill in real values before running validate_env.js
# NEVER commit real API keys.
# ============================================================

# --- Client Identity ---
CLIENT_NAME=soul_prosperity_demo
CLIENT_SLUG=soul-prosperity-demo
CLIENT_TIMEZONE=America/Chicago

# --- GoHighLevel (GHL) ---
GHL_SUBACCOUNT_ID=your-ghl-subaccount-id
GHL_API_KEY=your-ghl-api-key
GHL_WEBHOOK_URL=https://your-ghl-webhook-url.com/webhook
GHL_PIPELINE_ID=your-pipeline-id
GHL_STAGE_ID=your-stage-id

# --- Quiz Funnel URLs ---
QUIZ_URL=https://your-quiz-url.com
THANK_YOU_URL=https://your-thank-you-url.com
CALENDAR_URL=https://your-calendar-booking-url.com

# --- Meta Ads ---
META_PIXEL_ID=your-meta-pixel-id
META_ACCESS_TOKEN=your-meta-access-token
META_AD_ACCOUNT_ID=your-meta-ad-account-id

# --- TikTok Ads ---
TIKTOK_PIXEL_ID=your-tiktok-pixel-id
TIKTOK_ACCESS_TOKEN=your-tiktok-access-token

# --- Google Analytics 4 ---
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=your-ga4-api-secret

# --- Google Ads ---
GOOGLE_ADS_CONVERSION_ID=AW-XXXXXXXXXX
GOOGLE_ADS_CONVERSION_LABEL=your-conversion-label

# --- n8n Automation ---
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/soul-prosperity
N8N_WORKFLOW_ID=your-n8n-workflow-id

# --- Notifications ---
NOTIFY_EMAIL=owner@soulprosperity.com
NOTIFY_SLACK_WEBHOOK=https://hooks.slack.com/services/your/slack/webhook

# --- Deployment ---
DEPLOY_ENV=staging
DEPLOY_URL=https://your-deploy-url.com
