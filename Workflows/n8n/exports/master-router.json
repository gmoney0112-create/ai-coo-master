      "typeVersion": 1,
      "position": [750, 550],
      "parameters": {}
    },
    {
      "id": "a1b2c3d4-0001-0000-0000-000000000007",
      "name": "Alert — Unknown Type",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [750, 700],
      "parameters": {
        "chatId": "={{ $env.TELEGRAM_CHAT_ID }}",
        "text": "⚠️ Unknown payload type received: {{ $json.body.type }}\n\nFull payload:\n{{ JSON.stringify($json.body, null, 2) }}",
        "additionalFields": {}
      },
      "credentials": {
        "telegramApi": { "id": "1", "name": "Telegram Bot" }
      }
    }
  ],
  "connections": {
