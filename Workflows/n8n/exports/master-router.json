      "typeVersion": 1,
      "position": [750, 250],
      "parameters": {}
    },
    {
      "id": "a1b2c3d4-0001-0000-0000-000000000005",
      "name": "→ Tech Dept",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [750, 400],
      "parameters": {}
    },
    {
      "id": "a1b2c3d4-0001-0000-0000-000000000006",
